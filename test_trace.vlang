external function GetStdHandle(nStdHandle: i32) -> ptr<void>
external function WriteConsoleA(hConsole: ptr<void>, lpBuffer: ptr<u8>, nChars: u32, lpWritten: ptr<u32>, lpReserved: ptr<void>) -> i32
external function MessageBoxA(hwnd: u64, text: ptr<u8>, title: ptr<u8>, flags: u32) -> i32

function main() -> i32 {
    declare h: ptr<void> = GetStdHandle(-11)
    WriteConsoleA(h, "BEFORE MSGBOX\n", 14, cast<ptr<u32>>(0), cast<ptr<void>>(0))
    MessageBoxA(0, "Works?", "Test", 0)
    WriteConsoleA(h, "AFTER MSGBOX\n", 13, cast<ptr<u32>>(0), cast<ptr<void>>(0))
    return 0
}
